LLM_API_KEY=your_api_key_here
LLM_BASE_URL=https://api.llm.ustc.edu.cn
LLM_MODEL=deepseek-v4-flash
APP_TIMEZONE=Asia/Shanghai

# 加权综合分权重（论文）
WEIGHT_FRONTIER=0.40
WEIGHT_PRACTICAL=0.35
WEIGHT_RIGOR=0.25

# 精选阈值
FEATURED_THRESHOLD=7.5

# data.json 最大条目数
MAX_TOTAL_ITEMS=500

# 最低评分阈值
MIN_SCORE_AVG=6.0
MIN_SCORE_AVG_NEWS=5.0

# 出版商 API Key（可选，未配置时 fallback 到 RSS）
ELSEVIER_API_KEY=
SPRINGER_API_KEY=

# Semantic Scholar API Key（可选，无 key 时速率受限）
SEMANTIC_SCHOLAR_API_KEY=

# 抓取限流配置
REQUEST_DELAY_MIN=3
REQUEST_DELAY_MAX=8
MAX_RETRIES=3
DISABLE_SSL_VERIFY=false
